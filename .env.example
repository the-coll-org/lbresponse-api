PORT=3000
NODE_ENV=development

# Compose-only: host-side port to bind the container to.
# Set to a free port when 3000 is taken (e.g. HOST_PORT=3100 on a shared VPS).
HOST_PORT=3000

# Realtime Database URL (required)
FIREBASE_DB_URL=https://lbresponse-db.firebaseio.com

# --- Firebase credentials: pick ONE of the two paths below ---

# Option 1 (recommended for local dev): point at the JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option 2 (recommended for prod / Docker): individual env vars
# In .env, wrap the private key in double quotes so the literal \n survives.
FIREBASE_PROJECT_ID=lbresponse-db
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lbresponse-db.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=
