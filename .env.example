PORT=3000
NODE_ENV=development

# Compose-only: host-side port to bind the container to.
# Set to a free port when 3000 is taken (e.g. HOST_PORT=3100 on a shared VPS).
HOST_PORT=3000

# Realtime Database URL (required)
FIREBASE_DB_URL=https://lbresponse-db.firebaseio.com

# --- Firebase credentials: pick ONE of the two paths below ---

# Option 1 (recommended for local dev): point at the JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option 2 (recommended for prod / Docker): individual env vars
# In .env, wrap the private key in double quotes so the literal \n survives.
FIREBASE_PROJECT_ID=lbresponse-db
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lbresponse-db.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=

# --- Admin dashboard (/admin) -----------------------------------------------
# Comma-separated Google account emails allowed to sign in and administer data.
ADMIN_EMAILS=
# Public Firebase Web SDK config for the login page (NOT secret — these ship to
# the browser). Copy from Firebase console > Project settings > Your apps (Web).
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
# Admin session lifetime in hours (default 8). Set COOKIE_SECURE=false only for
# plain-HTTP local validation; leave unset (defaults to true in production).
ADMIN_SESSION_HOURS=8
# COOKIE_SECURE=

# --- Rate limiting (optional; sensible defaults applied) --------------------
# RATE_LIMIT_MAX=300                 # general requests per minute
# CLIENT_ERROR_RATE_LIMIT_MAX=30     # /api/client-errors posts per minute
# ADMIN_AUTH_RATE_LIMIT_MAX=20       # admin login attempts per 15 min
