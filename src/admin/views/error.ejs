<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · lbresponse admin</title>
    <style>
      body { font-family: system-ui, sans-serif; background: #0f172a; color: #e2e8f0; display: grid; place-items: center; min-height: 100vh; margin: 0; }
      .card { background: #1e293b; padding: 2.5rem; border-radius: 12px; max-width: 420px; text-align: center; }
      h1 { font-size: 1.2rem; margin: 0 0 .75rem; }
      p { color: #94a3b8; font-size: .9rem; }
      a { color: #93c5fd; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1><%= title %></h1>
      <p><%= message %></p>
      <p><a href="/admin/login">Back to login</a></p>
    </div>
  </body>
</html>
